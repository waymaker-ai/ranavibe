# Source files — NEVER publish TypeScript source
src/
__tests__/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
test/
tests/

# Build config
tsconfig.json
tsconfig.*.json
vitest.config.*
jest.config.*
.eslintrc*
.prettierrc*
turbo.json


*.map
*.js.map
*.d.ts.map

# Environment & secrets
.env
.env.*
*.pem
*.key

# Development artifacts
node_modules/
coverage/
.turbo/
.cache/
*.tsbuildinfo

# Documentation (keep README)
docs/
CHANGELOG.md
CONTRIBUTING.md

# Git & CI
.git/
.github/
.gitignore
.npmrc

# OS artifacts
.DS_Store
Thumbs.db

# CoFounder Development Environment
# Copy this file to .env and fill in your values

# ─── LLM Providers (at least one required) ──────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=

# ─── Database (for docker-compose) ──────────────────────────────────────────
POSTGRES_PASSWORD=luka-dev-password
POSTGRES_DB=luka
DATABASE_URL=postgresql://postgres:luka-dev-password@localhost:5432/luka

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Ollama (local models) ─────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ─── Object Storage (MinIO) ────────────────────────────────────────────────
MINIO_ROOT_USER=luka-admin
MINIO_ROOT_PASSWORD=luka-password

# ─── Monitoring (optional) ─────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── GitHub (for CI scanner PR comments) ───────────────────────────────────
GITHUB_TOKEN=
